{
  "name": "AI Reel Generator Pipeline",
  "nodes": [
    {
      "parameters": {
        "path": "reel-generator",
        "httpMethod": "POST",
        "responseMode": "responseNode"
      },
      "id": "Webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [200, 300]
    },

    {
      "parameters": {
        "functionCode": "return [{ json: { prompt: $json.prompt, sceneCount: $json.sceneCount || 5 } }];"
      },
      "id": "PrepareInput",
      "name": "Prepare Input",
      "type": "n8n-nodes-base.function",
      "position": [400, 300]
    },

    {
      "parameters": {
        "requestMethod": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "jsonParameters": true,
        "options": {},
        "bodyParametersJson": "={\n  \"model\": \"mixtral-8x7b-32768\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate {{$json.sceneCount}} cinematic image prompts for: {{$json.prompt}}. Return as JSON array.\"\n    }\n  ]\n}"
      },
      "id": "Groq",
      "name": "Generate Scenes (Groq)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [600, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "groq-api",
          "name": "Groq API"
        }
      }
    },

    {
      "parameters": {
        "functionCode": "const text = items[0].json.choices[0].message.content;\nlet scenes;\ntry { scenes = JSON.parse(text); } catch { scenes = text.split(\"\\n\"); }\nreturn scenes.map(s => ({ json: { scene: s } }));"
      },
      "id": "ParseScenes",
      "name": "Parse Scenes",
      "type": "n8n-nodes-base.function",
      "position": [800, 300]
    },

    {
      "parameters": {
        "batchSize": 1
      },
      "id": "Split",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [1000, 300]
    },

    {
      "parameters": {
        "requestMethod": "POST",
        "url": "https://api-inference.huggingface.co/models/stabilityai/stable-diffusion-2",
        "jsonParameters": true,
        "bodyParametersJson": "={\"inputs\": $json.scene }",
        "options": {
          "responseFormat": "file"
        }
      },
      "id": "HF",
      "name": "Generate Image (HF)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1200, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "hf-api",
          "name": "HF API"
        }
      }
    },

    {
      "parameters": {
        "filePath": "=/tmp/scene_{{$itemIndex}}.png"
      },
      "id": "SaveImage",
      "name": "Save Image",
      "type": "n8n-nodes-base.writeBinaryFile",
      "position": [1400, 300]
    },

    {
      "parameters": {},
      "id": "Merge",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "position": [1600, 300]
    },

    {
      "parameters": {
        "command": "ffmpeg -y -framerate 1/3 -i /tmp/scene_%d.png -c:v libx264 -pix_fmt yuv420p /tmp/output.mp4"
      },
      "id": "FFmpeg",
      "name": "Create Video",
      "type": "n8n-nodes-base.executeCommand",
      "position": [1800, 300]
    },

    {
      "parameters": {
        "functionCode": "const fileName = `video_${Date.now()}.mp4`;\nreturn [{ json: { fileName, publicPath: `/public/videos/${fileName}`, url: `/videos/${fileName}` } }];"
      },
      "id": "FileName",
      "name": "Generate File Name",
      "type": "n8n-nodes-base.function",
      "position": [2000, 300]
    },

    {
      "parameters": {
        "command": "mv /tmp/output.mp4 {{$json.publicPath}}"
      },
      "id": "MoveVideo",
      "name": "Move Video",
      "type": "n8n-nodes-base.executeCommand",
      "position": [2200, 300]
    },

    {
      "parameters": {
        "command": "rm /tmp/scene_*.png"
      },
      "id": "Cleanup",
      "name": "Cleanup Temp",
      "type": "n8n-nodes-base.executeCommand",
      "position": [2400, 300]
    },

    {
      "parameters": {
        "query": "INSERT INTO Videos (video_url, created_at) VALUES ('{{$json.url}}', GETDATE())"
      },
      "id": "DB",
      "name": "Save to MSSQL",
      "type": "n8n-nodes-base.microsoftSql",
      "position": [2600, 300],
      "credentials": {
        "microsoftSql": {
          "id": "mssql",
          "name": "MSSQL"
        }
      }
    },

    {
      "parameters": {
        "responseBody": "={\"success\": true, \"videoUrl\": $json.url }"
      },
      "id": "Response",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [2800, 300]
    }
  ],

  "connections": {
    "Webhook": { "main": [[{ "node": "Prepare Input", "type": "main" }]] },
    "Prepare Input": { "main": [[{ "node": "Groq", "type": "main" }]] },
    "Groq": { "main": [[{ "node": "Parse Scenes", "type": "main" }]] },
    "Parse Scenes": { "main": [[{ "node": "Split", "type": "main" }]] },
    "Split": { "main": [[{ "node": "Generate Image (HF)", "type": "main" }]] },
    "Generate Image (HF)": { "main": [[{ "node": "Save Image", "type": "main" }]] },
    "Save Image": { "main": [[{ "node": "Merge", "type": "main" }]] },
    "Merge": { "main": [[{ "node": "Create Video", "type": "main" }]] },
    "Create Video": { "main": [[{ "node": "Generate File Name", "type": "main" }]] },
    "Generate File Name": { "main": [[{ "node": "Move Video", "type": "main" }]] },
    "Move Video": { "main": [[{ "node": "Cleanup Temp", "type": "main" }]] },
    "Cleanup Temp": { "main": [[{ "node": "Save to MSSQL", "type": "main" }]] },
    "Save to MSSQL": { "main": [[{ "node": "Respond", "type": "main" }]] }
  }
}